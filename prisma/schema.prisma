datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum PaymentStatus {
  initiated
  completed
  failed
  cancelled
}

enum SettlementStatus {
  pending
  processing
  completed
  failed
}

model Merchant {
  id          String       @id
  name        String
  ownerId     String
  createdAt   DateTime     @default(now())
  deletedAt   DateTime?
  settings    Json?
  payments    Payment[]
  settlements Settlement[]
}

model Payment {
  id                      String        @id
  merchantId              String
  merchant                Merchant      @relation(fields: [merchantId], references: [id])
  payerId                 String?
  amount                  Decimal       @db.Decimal(18, 6)
  asset                   String
  status                  PaymentStatus @default(initiated)
  reference               String?
  createdAt               DateTime      @default(now())
  // Idempotency support: optional client-supplied key with 24-hour TTL.
  // The @unique constraint is the database-level race guard that prevents
  // duplicate creation even under concurrent requests.
  idempotencyKey          String?       @unique
  idempotencyKeyExpiresAt DateTime?
}

model Settlement {
  id          String           @id
  merchantId  String
  merchant    Merchant         @relation(fields: [merchantId], references: [id])
  totalAmount String
  grossAmount String
  feeAmount   String
  netAmount   String
  feeBps      Int
  asset       String
  status      SettlementStatus @default(pending)
  webhookUrl  String?
  initiatedAt DateTime         @default(now())
  completedAt DateTime?
}
